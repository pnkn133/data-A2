{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Graduate Full-Time Employment Softened in 2024",
    "subtitle": "Full-time employment outcomes by course level, 2022-2024. Source: QILT Graduate Outcomes Survey 2024 National Report Tables.",
    "anchor": "start",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "subtitleColor": "#555"
  },
  "width": 680,
  "height": 330,
  "background": "#ffffff",
  "data": {
    "url": "data/qilt_graduate_fulltime_employment_2022_24.csv",
    "format": {
      "type": "csv",
      "parse": {
        "year": "number",
        "full_time_employment_pct": "number",
        "overall_employment_pct": "number",
        "labour_force_participation_pct": "number"
      }
    }
  },
  "transform": [
    {
      "calculate": "datum.year == 2024 ? datum.course_level_short + ' ' + format(datum.full_time_employment_pct, '.1f') + '%' : ''",
      "as": "end_label"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "line",
        "point": {
          "filled": true,
          "size": 80
        },
        "strokeWidth": 3
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": "Survey year",
          "axis": {
            "labelAngle": 0
          }
        },
        "y": {
          "field": "full_time_employment_pct",
          "type": "quantitative",
          "title": "Full-time employment (%)",
          "scale": {
            "domain": [
              70,
              92
            ],
            "nice": false
          },
          "axis": {
            "format": ".0f",
            "grid": true,
            "tickCount": 6
          }
        },
        "color": {
          "field": "course_level",
          "type": "nominal",
          "title": "Course level",
          "scale": {
            "domain": [
              "Undergraduate",
              "Postgraduate coursework",
              "Postgraduate research"
            ],
            "range": [
              "#1f7a8c",
              "#a463f2",
              "#d68a59"
            ]
          },
          "legend": {
            "orient": "bottom",
            "direction": "horizontal",
            "titleLimit": 180,
            "labelLimit": 190
          }
        },
        "detail": {
          "field": "course_level",
          "type": "nominal"
        },
        "tooltip": [
          {
            "field": "course_level",
            "type": "nominal",
            "title": "Course level"
          },
          {
            "field": "year",
            "type": "ordinal",
            "title": "Year"
          },
          {
            "field": "full_time_employment_pct",
            "type": "quantitative",
            "title": "Full-time employment",
            "format": ".1f"
          },
          {
            "field": "overall_employment_pct",
            "type": "quantitative",
            "title": "Overall employment",
            "format": ".1f"
          },
          {
            "field": "labour_force_participation_pct",
            "type": "quantitative",
            "title": "Labour force participation",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.end_label != ''"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 10,
        "fontSize": 12,
        "fontWeight": 700
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "y": {
          "field": "full_time_employment_pct",
          "type": "quantitative"
        },
        "text": {
          "field": "end_label"
        },
        "color": {
          "field": "course_level",
          "type": "nominal",
          "scale": {
            "domain": [
              "Undergraduate",
              "Postgraduate coursework",
              "Postgraduate research"
            ],
            "range": [
              "#1f7a8c",
              "#a463f2",
              "#d68a59"
            ]
          },
          "legend": null
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "font": "Inter, Arial, sans-serif",
    "axis": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelColor": "#333",
      "titleColor": "#333",
      "gridColor": "#e5e8e2",
      "domain": false
    },
    "legend": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelColor": "#333",
      "titleColor": "#333"
    },
    "title": {
      "font": "Inter, Arial, sans-serif",
      "fontWeight": 700,
      "color": "#202124"
    }
  }
}
